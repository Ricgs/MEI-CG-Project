<?xml version="1.0" ?>
<project name="Biblioteca de BRDFs" width="1024" height="768">
    <assets>

        <attributes>
            <attribute type="RENDERER" name="albedo" data="VEC3" x="5.0" y="5.0" z="5.0" />
            <attribute type="RENDERER" name="emissivity" data="VEC3" x="0.0" y="0.0" z="0.0" />
            <attribute type="RENDERER" name="baseflect" data="VEC3" x="0.04" y="0.04" z="0.04" /> 
            <attribute type="RENDERER" name="roughness" data="FLOAT" value="0.3" />
        </attributes>

        <cameras>
            <camera name="MainCamera">
                <viewport name="MainViewport" />
                <TYPE value="PERSPECTIVE" />
                <NEAR value="0.01" />
                <POSITION x="0.586" y="5.036" z="-10.636" />
                <VIEW x="0.0" y="0.0" z="-1.0" />
                <LOOK_AT_POINT x="0.562" y="4.750" z="-9.678" />
            </camera>
        </cameras>

        <viewports>
            <viewport name="MainViewport" >
                <CLEAR_COLOR x="0.0" y="0.0" z="0.0" /> 
            </viewport>
        </viewports>

        <lights>
            <light name="Sun">
                <DIRECTION x="-0.5" y="-1.0" z="-0.5" />
                <COLOR r="0.0" g="0.0" b="0.0" />
            </light>
        </lights>

        <scenes>
            <scene name="Sphere">
                <TRANSLATE x="0" y="1" z="0" />
                <file name="models/sphere.obj"/>
            </scene>
            <scene name="Plane" >
				<SCALE x="50" y="50" z="50" />
				<file name="models/plane.obj"/>
			</scene>
            <scene name="SkyBox" >
                <geometry name="skyBox" material="skybox" type="BOX" >
                    <SCALE x="10" y="10" z="10" />
                </geometry>
            </scene>
        </scenes>

        <materialLibs>
            <materialLib filename="material.mlib" />
        </materialLibs>
    </assets>

    <pipelines>
        <pipeline name="FixedPipeline" default="true">

            <pass class="default" name="SkyBox">
                <COLOR_CLEAR value="false" />

                <scenes>
                    <scene name="SkyBox" />
                </scenes>

                <camera name="MainCamera" />

                <materialMaps>
                    <map fromMaterial="*" toLibrary="MyLib" toMaterial="MatSkybox" />
                </materialMaps>
            </pass>

            <!--pass class="default" name="Plane" >
                <COLOR_CLEAR value="false" />

				<scenes>
                    <scene name="Plane" />
                </scenes>

                <camera name="MainCamera" />

                <lights>
                    <light name="Sun" />
                </lights>

                <materialMaps>
                    <map fromMaterial="*" toLibrary="MyLib" toMaterial="MatFloor" />
                </materialMaps>
			</pass-->

            <pass class="default" name="Spheres">
                <COLOR_CLEAR value="false" />

                <scenes instances="5">
                    <scene name="Sphere" />
                </scenes>

                <camera name="MainCamera" />

                <lights>
                    <light name="Sun" />
                </lights>

                <materialMaps>
                    <map fromMaterial="*" toLibrary="MyLib" toMaterial="MatBRDF" />
                </materialMaps>
            </pass>

        </pipeline>
    </pipelines>

    <interface>
        <window label="Controlos PBR">
            <var label="Cor Albedo" type="RENDERER" context="CURRENT" component="albedo" mode="COLOR" />
            <var label="Emissividade" type="RENDERER" context="CURRENT" component="emissivity" mode="COLOR" />
            <var label="Refletância Base (F0)" type="RENDERER" context="CURRENT" component="baseflect" mode="COLOR" />
            <var label="Roughness" type="RENDERER" context="CURRENT" component="roughness" def="min=0.01 max=1.0" />
        </window>

        <window label="Configuração de Iluminação">
            <var label="Cor do Sol" type="LIGHT" context="Sun" component="COLOR" mode="COLOR" def="min=-50.0 max=50.0"/>
            <var label="Direção do Sol" type="LIGHT" context="Sun" component="DIRECTION" def="min=-50.0 max=50.0"/>
        </window>
    </interface>
</project>